# Copy to .env for local overrides. The docker-compose file already sets safe
# dev defaults inline, so this file is documentation + a template for real
# deployments. NEVER commit a real .env (secrets live only in the environment).

APP_ENV=dev
SECRET_KEY=dev-insecure-secret-change-me

# Direct Postgres (used by Alembic migrations and as the fallback engine URL).
DATABASE_URL=postgresql+asyncpg://psych:psych@postgres:5432/psych
# Through PgBouncer (transaction mode) — the app runtime path.
PGBOUNCER_URL=postgresql+asyncpg://psych:psych@pgbouncer:6432/psych

REDIS_URL=redis://redis:6379/0

# Catalog seeding
DEFINITION_SEED_PATH=mmpi_v1.json
TEST_SLUG=mmpi-teen-13

# Garage / S3 — unused until Phase 6 (reports).
GARAGE_ENDPOINT=
GARAGE_KEY=
GARAGE_SECRET=
GARAGE_BUCKET=reports
