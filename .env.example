# Copy to .env for local overrides. The docker-compose file already sets safe
# dev defaults inline, so this file is documentation + a template for real
# deployments. NEVER commit a real .env (secrets live only in the environment).

APP_ENV=dev
SECRET_KEY=dev-insecure-secret-change-me

# Direct Postgres (used by Alembic migrations and as the fallback engine URL).
DATABASE_URL=postgresql+asyncpg://psych:psych@postgres:5432/psych
# Through PgBouncer (transaction mode) — the app runtime path.
PGBOUNCER_URL=postgresql+asyncpg://psych:psych@pgbouncer:6432/psych

REDIS_URL=redis://redis:6379/0

# Catalog seeding
DEFINITION_SEED_PATH=mmpi_v1.json
TEST_SLUG=mmpi-teen-13

# ── Sessions & cookies (Phase 2) ─────────────────────────────────────────────
# COOKIE_SECURE must be true in any HTTPS deployment (off here for dev http).
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
SESSION_TTL_SECONDS=1209600

# ── OTP + rate limits (Phase 2) ──────────────────────────────────────────────
OTP_TTL_SECONDS=120
OTP_CODE_LENGTH=5
OTP_MAX_ATTEMPTS=5
OTP_PHONE_COOLDOWN_SECONDS=60
OTP_PHONE_HOURLY_MAX=5
OTP_IP_HOURLY_MAX=20
# Unknown phone on verify → create a source='local' user (signup == login).
OTP_AUTO_CREATE_USERS=true

# ── Passwords (Phase 3) ──────────────────────────────────────────────────────
PASSWORD_MIN_LENGTH=8
# Brute-force guard on username/password login (counts only failed attempts).
PASSWORD_LOGIN_WINDOW_SECONDS=900
PASSWORD_LOGIN_SUBJECT_MAX=10
PASSWORD_LOGIN_IP_MAX=50

# ── SMS / Kavenegar (Phase 2) ────────────────────────────────────────────────
# mock = log the code (dev/test); kavenegar = send for real.
SMS_BACKEND=mock
KAVENEGAR_API_KEY=
KAVENEGAR_SENDER=
KAVENEGAR_USE_TEMPLATE=false
KAVENEGAR_OTP_TEMPLATE=
# OTP_MESSAGE_TEMPLATE must contain {code}.
OTP_MESSAGE_TEMPLATE=کد ورود شما: {code}

# ── Celery (Phase 2) ─────────────────────────────────────────────────────────
# Default to REDIS_URL when blank.
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# ── Admin bootstrap (Phase 2) — provisions the first admin, idempotently ──────
# Set your own phone; never commit a real number. Re-running won't duplicate.
SEED_ADMIN_PHONE=
SEED_ADMIN_USERNAME=

# ── WordPress bidirectional sync (Phase 4) ───────────────────────────────────
# BOTH directions use the WP REST API (never MySQL). Off by default and pointed at
# an in-memory fake so dev/test never touch the network. To go live, set:
#   WP_SYNC_ENABLED=true and WP_CLIENT_BACKEND=http and the WP_* credentials below.
# The phone usermeta (join key) + a modified timestamp must be exposed to REST by
# the must-use plugin in wordpress/mu-plugins/pst-sync.php.
WP_SYNC_ENABLED=false
WP_CLIENT_BACKEND=fake
# REST root, e.g. https://your-site.tld/wp-json   (NO trailing slash needed)
WP_REST_BASE=
# Least-privilege WP account login + its Application Password. The app password is
# a SECRET — set it only in the real environment, NEVER commit it.
WP_API_USER=
WP_API_APP_PASSWORD=
# Usermeta keys the mu-plugin exposes to REST.
WP_PHONE_META_KEY=billing_phone
WP_MODIFIED_META_KEY=pst_modified_gmt
# Read sync (WP → app): 'full' (scan all, catches edits) | 'incremental' (new only).
WP_PULL_MODE=full
WP_PULL_PAGE_SIZE=100
WP_SYNC_INTERVAL_MINUTES=10
WP_RECONCILE_INTERVAL_MINUTES=15
# Write sync (app → WP): 'synthesize' (push phone-only signups using a derived
# username + placeholder email) | 'defer' (push only once a real email exists) |
# 'manual' (admin "sync now" only).
WP_PUSH_POLICY=synthesize
WP_DEFAULT_ROLE=subscriber
WP_PLACEHOLDER_EMAIL_DOMAIN=users.invalid
WP_HTTP_TIMEOUT_SECONDS=15.0

# Garage / S3 — unused until Phase 6 (reports).
GARAGE_ENDPOINT=
GARAGE_KEY=
GARAGE_SECRET=
GARAGE_BUCKET=reports
